generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

enum StatusKey {
  Enable
  Disable
}

model Licence {
  id          Int       @id @default(autoincrement())
  key         String    @unique
  hwid        String?
  status      StatusKey @default(Enable)
  expDays     Int?
  expireAt    DateTime?
  activatedAt DateTime?

  historyActivations HistoryKeyActivated[]

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([key])
  @@index([hwid])
}

model HistoryKeyActivated {
  id          Int       @id @default(autoincrement())
  licenceId   Int
  activatedAt DateTime  @default(now())
  licence     Licence   @relation(fields: [licenceId], references: [id])
  @@index([licenceId])
  @@index([activatedAt])
}


model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  role      String   @default("admin")
  createdAt DateTime @default(now())
}
