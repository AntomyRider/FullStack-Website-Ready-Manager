generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

enum StatusKey {
  Enable
  Disable
}

model License {
  id                 Int                    @id @default(autoincrement())
  key                String                 @unique
  hwid               String?
  status             StatusKey              @default(Enable)
  expDays            Int?
  expireAt           DateTime?
  activatedAt        DateTime?

  lastHeartbeatAt      DateTime?
  currentSessionStartAt DateTime?
  totalUsageSeconds    Int                    @default(0)

  resetAt            DateTime?
  resetCooldownAt    DateTime?
  resetCount         Int      @default(0)
  usedBy    String?

  historyActivations HistoryKeyActivated[]
  createdAt          DateTime               @default(now())
  updatedAt          DateTime               @updatedAt

  @@index([key])
  @@index([hwid])
}

model HistoryKeyActivated {
  id          Int       @id @default(autoincrement())
  licenseId   Int
  activatedAt DateTime  @default(now())
  license     License  @relation(fields: [licenseId], references: [id])
  @@index([licenseId])
  @@index([activatedAt])
}

model Claim {
  id        Int       @id @default(autoincrement())
  key       String    @unique
  discordId String
  claimedAt DateTime  @default(now())

  @@index([discordId])
}

model User {
  id        Int       @id @default(autoincrement())
  email     String    @unique
  password  String
  role      String    @default("admin")
  createdAt DateTime  @default(now())
}

model VerifiedSlip {
  id         Int      @id @default(autoincrement())
  transRef   String   @unique
  payload    String   @unique @db.VarChar(500)
  discordId  String
  amount     Float
  verifiedAt DateTime @default(now())

  @@index([transRef])
  @@index([payload])
}

model PurchaseHistory {
  id            Int      @id @default(autoincrement())
  discordId     String
  key           String
  amount        Float
  days          Int
  paymentMethod String   @default("bank")
  transRef      String?  @unique
  senderName    String?
  senderBank    String?
  purchasedAt   DateTime @default(now())

  @@index([discordId])
  @@index([purchasedAt])
}

model BotConfig {
  id               Int      @id @default(1)
  price1Day        Int      @default(19)
  price7Days       Int      @default(69)
  price30Days      Int      @default(169)
  priceLifetime    Int      @default(199)
  embedImageUrl    String   @db.VarChar(512)
  embedTitle       String   @default("READY MANAGER : โปรแกรมช่วยโพสต์")
  embedDescription String   @db.Text
  bankName         String   @default("กรุงไทย")
  bankHolder       String   @default("นครินทร์ งานยางหวาย")
  bankAccount      String   @default("4280686564")
  adminPhone       String   @default("0832584267")
  verifyChannelId  String   @default("1506243441007398964")
  logChannelId     String   @default("1512868304891412572")
  updatedAt        DateTime @updatedAt
}


