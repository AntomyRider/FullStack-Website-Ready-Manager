generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

enum StatusKey {
  Enable
  Disable
}

model License {
  id                 Int                    @id @default(autoincrement())
  key                String                 @unique
  hwid               String?
  status             StatusKey              @default(Enable)
  expDays            Int?
  expireAt           DateTime?
  activatedAt        DateTime?

  resetAt            DateTime?
  resetCooldownAt    DateTime?
  resetCount         Int      @default(0)
  usedBy    String?

  historyActivations HistoryKeyActivated[]
  createdAt          DateTime               @default(now())
  updatedAt          DateTime               @updatedAt

  @@index([key])
  @@index([hwid])
}

model HistoryKeyActivated {
  id          Int       @id @default(autoincrement())
  licenseId   Int
  activatedAt DateTime  @default(now())
  license     License  @relation(fields: [licenseId], references: [id])
  @@index([licenseId])
  @@index([activatedAt])
}

model Claim {
  id        Int       @id @default(autoincrement())
  key       String    @unique
  discordId String
  claimedAt DateTime  @default(now())

  @@index([discordId])
}

model User {
  id        Int       @id @default(autoincrement())
  email     String    @unique
  password  String
  role      String    @default("admin")
  createdAt DateTime  @default(now())
}

model VerifiedSlip {
  id         Int      @id @default(autoincrement())
  transRef   String   @unique
  payload    String   @unique @db.VarChar(500)
  discordId  String
  amount     Float
  verifiedAt DateTime @default(now())

  @@index([transRef])
  @@index([payload])
}

model PurchaseHistory {
  id            Int      @id @default(autoincrement())
  discordId     String
  key           String
  amount        Float
  days          Int
  paymentMethod String   @default("bank")
  transRef      String?  @unique
  senderName    String?
  senderBank    String?
  purchasedAt   DateTime @default(now())

  @@index([discordId])
  @@index([purchasedAt])
}

