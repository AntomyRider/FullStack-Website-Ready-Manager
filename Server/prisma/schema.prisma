generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

enum StatusKey {
  Enable
  Disable
}

model Licence {
  id          Int       @id @default(autoincrement())
  key         String    @unique
  hwid        String?
  status      StatusKey @default(Enable)
  expireAt    DateTime?
  activatedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([key])
  @@index([hwid])
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  role      String   @default("admin")
  createdAt DateTime @default(now())
}
